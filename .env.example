# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit real credentials.

# OpenAI
OPENAI_API_KEY=sk-...

# Cohere reranker (get from https://dashboard.cohere.com — optional)
# If absent, pipeline falls back to RRF-fused results without reranking.
COHERE_API_KEY=...

# LangSmith tracing (get from https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=instacart-recsys

# DeepEval metrics (adds ~10-20 s per run; uses gpt-4o-mini as judge)
# Set to true to enable faithfulness, hallucination, retrieval quality, compliance risk scoring
DEEPEVAL_METRICS=false
